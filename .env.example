# ═══ Market Platform Unified — Variáveis de Ambiente ═══

# Banco de dados (PostgreSQL)
MARKET_DB_URL=postgresql+psycopg2://postgres:SUA_SENHA@localhost:5432/market_db

# Para usar SQLite (desenvolvimento sem PostgreSQL):
# MARKET_DB_URL=sqlite:///./market_dev.db

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Ingestão
INGEST_BATCH_SIZE=20
INGEST_RATE_LIMIT=0.5
INGEST_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
