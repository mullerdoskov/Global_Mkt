# Conexão com o banco de dados
# SQLite (padrão para desenvolvimento):
MARKET_DB_URL=sqlite:///market_db.sqlite

# PostgreSQL (produção — descomente e comente a linha acima):
# MARKET_DB_URL=postgresql+psycopg2://postgres:sua_senha@localhost:5432/market_db

# CORS — origens permitidas (separar por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API configuration
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000

# Debug mode
DEBUG=false

# Rate limiting (slowapi) — ISSUE-010
# Vocabulário do `limits`: <count>/<seconds|minute|hour|day> (ex.: "60/minute").
# Aplicado a todos os endpoints sob /api. /health e /api/info ficam fora.
RATE_LIMIT_DEFAULT=60/minute
# Limite mais agressivo para o endpoint de exportação CSV (ISSUE-017).
# CSV é endpoint de extração: response grande, custo de banco alto. 10/min/IP
# permite uso humano normal mas corta scraping. Sobrescreve para o endpoint
# `/api/export/{symbol}.csv` apenas; demais endpoints continuam em RATE_LIMIT_DEFAULT.
RATE_LIMIT_EXPORT=10/minute
# Em produção: true. Em testes: false (já configurado em conftest.py).
RATE_LIMIT_ENABLED=true

# Cache (fastapi-cache2) — ISSUE-011
# REDIS_URL é opcional. Se setada e o Redis estiver acessível, o backend de
# cache vira RedisBackend (compartilhado entre workers / instâncias). Se não
# setada (ou Redis inacessível), cai em InMemoryBackend (process-local).
# Suba Redis para dev local com: docker compose -f docker-compose.dev.yml up -d
# REDIS_URL=redis://localhost:6379/0
# Em produção: true. Em testes: false (já configurado em conftest.py).
CACHE_ENABLED=true

# Agendamento (ISSUE-015)
# Diretório onde `backend.scheduling.incremental_update` grava os logs
# de cada run agendado. Default: <repo>/logs/scheduler/. Use um path
# fora do repo (ex.: C:\ProgramData\MDP\logs) se quiser separar logs
# operacionais do checkout de código.
# SCHEDULER_LOG_DIR=

# Backup automatico do PostgreSQL — ISSUE-023
# Diretorio destino dos arquivos .dump (formato pg_dump custom -Fc, ja
# comprimido). Default: <repo>/backups/postgres/. Use um path fora do
# repo (ex.: D:\backups\mdp) se quiser separar do checkout. Tipicamente
# 2-3 GB por dump apos meses de ingestao — escolha disco com folga.
# BACKUP_DIR=
# Idade maxima em dias acima da qual .dump antigo e deletado pelo
# wrapper. Default: 90 (~12 semanas, ~3 meses). Schedule semanal +
# retencao 90 dias = ~12 dumps na janela.
# BACKUP_RETENTION_DAYS=90
# Diretorio dos logs do wrapper (separado dos logs do scheduler).
# Default: <repo>/logs/backups/.
# BACKUP_LOG_DIR=

# Watchlist persistente — ISSUE-018
# Rate limits dedicados ao endpoint de watchlist. Read mais frouxo que o
# default porque a UI pode poll; write mais apertado para cortar spam.
RATE_LIMIT_WATCHLIST_READ=120/minute
RATE_LIMIT_WATCHLIST_WRITE=30/minute
# Cookie de sessão. Em produção (HTTPS) manter true. Em dev local sobre
# http://localhost:8000, setar false (senão o browser não envia o cookie
# de volta e a watchlist some entre requests).
SESSION_COOKIE_NAME=mdp_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_MAX_AGE_SECONDS=315360000  # ~10 anos
